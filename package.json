    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~7.0.2",
    "angular-eslint": "^22.0.0",
    "typescript-eslint": "^8.63.0",
    "@eslint/js": "^10.0.1"
  }
